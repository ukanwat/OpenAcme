{
  "name": "@openacme/skills",
  "version": "0.5.2",
  "description": "Skill loader for OpenAcme — discovers and loads skill bundles from disk.",
  "license": "MIT",
  "author": "Utkarsh Kanwat",
  "homepage": "https://github.com/ukanwat/OpenAcme/tree/main/packages/skills#readme",
  "bugs": "https://github.com/ukanwat/OpenAcme/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ukanwat/OpenAcme.git",
    "directory": "packages/skills"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "builtin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build",
    "check-types": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@openacme/config": "workspace:*",
    "adm-zip": "^0.5.17",
    "giget": "^3.2.0",
    "gray-matter": "^4.0.3",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.15.3",
    "typescript": "5.9.2"
  }
}
