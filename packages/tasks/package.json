{
  "name": "@openacme/tasks",
  "version": "0.7.0",
  "description": "File-backed task store for OpenAcme — markdown + YAML frontmatter, atomic writes, dependency enforcement, per-session queues.",
  "license": "MIT",
  "author": "Utkarsh Kanwat",
  "homepage": "https://github.com/ukanwat/OpenAcme/tree/main/packages/tasks#readme",
  "bugs": "https://github.com/ukanwat/OpenAcme/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ukanwat/OpenAcme.git",
    "directory": "packages/tasks"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build",
    "check-types": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@openacme/config": "workspace:*",
    "croner": "^10.0.1",
    "gray-matter": "^4.0.3",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "typescript": "5.9.2",
    "vitest": "^2.1.9"
  }
}
