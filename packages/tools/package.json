{
  "name": "@openacme/tools",
  "version": "0.2.0",
  "description": "Tool definitions and helpers for OpenAcme agents.",
  "license": "MIT",
  "author": "Utkarsh Kanwat",
  "homepage": "https://github.com/ukanwat/OpenAcme/tree/main/packages/tools#readme",
  "bugs": "https://github.com/ukanwat/OpenAcme/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ukanwat/OpenAcme.git",
    "directory": "packages/tools"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build && node -e \"require('fs').cpSync('src/builtins/python_repl','dist/builtins/python_repl',{recursive:true})\"",
    "check-types": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "@openacme/config": "workspace:*",
    "@openacme/db": "workspace:*",
    "jsdom": "^25.0.1",
    "turndown": "^7.2.0",
    "zod": "^3.24.4",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.3",
    "@types/turndown": "^5.0.5",
    "better-sqlite3": "^11.7.0",
    "typescript": "5.9.2",
    "vitest": "^2.1.9"
  }
}
