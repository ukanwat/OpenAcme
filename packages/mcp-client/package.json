{
  "name": "@openacme/mcp-client",
  "version": "0.4.0",
  "description": "Model Context Protocol client used by OpenAcme to talk to MCP servers.",
  "license": "MIT",
  "author": "Utkarsh Kanwat",
  "homepage": "https://github.com/ukanwat/OpenAcme/tree/main/packages/mcp-client#readme",
  "bugs": "https://github.com/ukanwat/OpenAcme/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ukanwat/OpenAcme.git",
    "directory": "packages/mcp-client"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build",
    "check-types": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openacme/config": "workspace:*",
    "@openacme/tools": "workspace:*",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "typescript": "5.9.2",
    "vitest": "^2.1.9"
  }
}
