{
  "name": "@openacme/server",
  "version": "0.6.0",
  "description": "HTTP server for the OpenAcme AI agent platform.",
  "license": "MIT",
  "author": "Utkarsh Kanwat",
  "homepage": "https://github.com/ukanwat/OpenAcme/tree/main/packages/server#readme",
  "bugs": "https://github.com/ukanwat/OpenAcme/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ukanwat/OpenAcme.git",
    "directory": "packages/server"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "web",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build",
    "check-types": "tsc --noEmit",
    "dev": "node scripts/dev.mjs",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepack": "rm -rf web && cp -r ../../apps/web/out web"
  },
  "dependencies": {
    "@openacme/agent-catalog": "workspace:*",
    "@openacme/browser": "workspace:*",
    "@openacme/config": "workspace:*",
    "@openacme/db": "workspace:*",
    "@openacme/llm-provider": "workspace:*",
    "@openacme/memory": "workspace:*",
    "@openacme/tasks": "workspace:*",
    "@openacme/tools": "workspace:*",
    "@openacme/agent-core": "workspace:*",
    "@openacme/mcp-client": "workspace:*",
    "@openacme/skills": "workspace:*",
    "@openacme/auth": "workspace:*",
    "ai": "^6.0.177",
    "croner": "^10.0.1",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0",
    "dotenv": "^16.5.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.3",
    "@types/web-push": "^3.6.4",
    "better-sqlite3": "^11.7.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.2",
    "vitest": "^2.1.9"
  }
}
