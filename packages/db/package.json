{
  "name": "@openacme/db",
  "version": "0.5.1",
  "description": "SQLite-backed persistence layer (drizzle-orm) for OpenAcme.",
  "license": "MIT",
  "author": "Utkarsh Kanwat",
  "homepage": "https://github.com/ukanwat/OpenAcme/tree/main/packages/db#readme",
  "bugs": "https://github.com/ukanwat/OpenAcme/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ukanwat/OpenAcme.git",
    "directory": "packages/db"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "drizzle",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build",
    "check-types": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@openacme/config": "workspace:*",
    "@openacme/tasks": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.44.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.3",
    "drizzle-kit": "^0.31.10",
    "typescript": "5.9.2",
    "vitest": "^2.1.9"
  }
}
