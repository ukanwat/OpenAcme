{
  "name": "@openacme/cli",
  "version": "0.1.1",
  "description": "CLI for the OpenAcme AI agent platform — install globally to get the `openacme` command.",
  "license": "MIT",
  "author": "Utkarsh Kanwat",
  "homepage": "https://github.com/ukanwat/OpenAcme/tree/main/apps/cli#readme",
  "bugs": "https://github.com/ukanwat/OpenAcme/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ukanwat/OpenAcme.git",
    "directory": "apps/cli"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "type": "module",
  "bin": {
    "openacme": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build",
    "check-types": "tsc --noEmit",
    "dev": "tsc --watch",
    "cli": "node dist/index.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@openacme/config": "workspace:*",
    "@openacme/llm-provider": "workspace:*",
    "@openacme/server": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.15.3",
    "typescript": "5.9.2"
  }
}
