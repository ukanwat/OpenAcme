    "@openacme/config": "workspace:*",
    "@openacme/db": "workspace:*",
    "@openacme/llm-provider": "workspace:*",
    "@openacme/mcp-client": "workspace:*",
    "@openacme/memory": "workspace:*",
    "@openacme/server": "workspace:*",
    "@openacme/skills": "workspace:*",
    "@openacme/tasks": "workspace:*",
    "@openacme/tools": "workspace:*",
    "chalk": "^5.4.1",
    "cli-highlight": "^2.1.11",
    "commander": "^13.1.0",
    "figlet": "^1.11.0",
    "fzf": "^0.5.2",
    "globby": "^16.2.0",
    "gradient-string": "^3.0.0",
    "ink": "^7.0.2",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ora": "^8.2.0",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "typescript": "5.9.2"
  }
